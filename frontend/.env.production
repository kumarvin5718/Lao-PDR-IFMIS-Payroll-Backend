# Docker / nginx: call API on the same origin (https://host:18443/api/...).
# Overrides .env.local so production builds are not pinned to localhost:8000.
VITE_API_BASE_URL=

# Superset embedded dashboard (UUID from Superset → Dashboard → ⋮ → Embed dashboard)
VITE_SUPERSET_DASHBOARD_ID=0a6feae4-3726-480b-a07b-bf1750b67893
# Optional if nginx serves Superset at /superset on the same origin (default).
# VITE_SUPERSET_ORIGIN=https://localhost:18443/superset
