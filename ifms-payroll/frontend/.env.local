# Same-origin API (Docker nginx https://…:18443 → /api/v1). Required for production build
# when the app is served over HTTPS; do not point at http://localhost:8000 or the browser
# will block mixed-content requests to the API.
VITE_API_BASE_URL=

# For local `npm run dev` with API on port 8000 only, use:
# VITE_API_BASE_URL=http://localhost:8000
