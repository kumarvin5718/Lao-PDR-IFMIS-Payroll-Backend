# API (docker-compose passes these into the `api` service)
DB_ROOT_PASS=changeme_root
DB_APP_PASS=changeme_app
# Optional: set COOKIE_SECURE=false if you run the API on plain HTTP (e.g. uvicorn :8000 + Vite :5173).
# COOKIE_SECURE=false
# Optional: APP_DEBUG=true — 500 responses include exception message (troubleshooting only).
# APP_DEBUG=false
# Optional: PAYROLL_RUN_SYNC=true — POST /payroll/run runs in-process (no Celery worker). Default false.
# PAYROLL_RUN_SYNC=false
SUPERSET_DB_USER=superset_user
SUPERSET_DB_PASS=changeme_superset
# Must be >= 32 characters (JWT signing).
JWT_SECRET_KEY=changeme_jwt_secret_minimum_32_chars_long
SUPERSET_SECRET_KEY=changeme_superset_min32chars
SUPERSET_ADMIN_USER=superset_admin
SUPERSET_ADMIN_PASS=changeme_superset_admin
VALKEY_PASS=changeme_valkey
FLOWER_PASS=changeme_flower
