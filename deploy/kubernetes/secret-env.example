# Copy to a local file (never commit) and create the Secret:
#   kubectl create secret generic ifms-payroll-app-secrets -n ifms-payroll --from-env-file=./prod.env
#
# Required keys (see backend/app/config.py):
#   DATABASE_URL=postgresql+asyncpg://payroll_app:PASSWORD@rds-endpoint:5432/payroll_db
#   ALEMBIC_DATABASE_URL=postgresql+psycopg2://postgres:PASSWORD@rds-endpoint:5432/payroll_db
#   VALKEY_URL=redis://:PASSWORD@elasticache-endpoint:6379/0
#   CELERY_BROKER_URL=redis://:PASSWORD@elasticache-endpoint:6379/1
#   SECRET_KEY=<min 32 chars>
#   SUPERSET_ADMIN_USER=...
#   SUPERSET_ADMIN_PASS=...
#
# Optional:
#   PAYROLL_RUN_SYNC=false
#   UPLOAD_DIR=/app/uploads
#   REPORTS_DIR=/app/reports
